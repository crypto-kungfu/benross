---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'light' | 'inverse';
  class?: string;
}

const { href, variant = 'primary', class: className = '' } = Astro.props;

const variants = {
  primary: 'bg-brand-red text-white hover:bg-brand-red-dark',
  secondary: 'border border-brand-red text-brand-red hover:bg-brand-red hover:text-white',
  light: 'bg-white text-brand-red hover:bg-brand-cream',
  inverse: 'border border-white text-white hover:bg-white hover:text-brand-red',
};
---

<a
  href={href}
  class={`inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-extrabold shadow-sm transition ${variants[variant]} ${className}`}
>
  <slot />
</a>
