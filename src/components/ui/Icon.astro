---
interface Props {
  name:
    | 'shield'
    | 'certificate'
    | 'badge'
    | 'star'
    | 'phone'
    | 'clock'
    | 'pin'
    | 'check'
    | 'leaf'
    | 'arrow';
  class?: string;
}

const { name, class: className = 'h-6 w-6' } = Astro.props;

const paths: Record<Props['name'], string> = {
  shield: '<path d="M12 3l7 3v5c0 4.5-3 8.2-7 10-4-1.8-7-5.5-7-10V6l7-3z"/><path d="M9 12l2 2 4-4"/>',
  certificate: '<circle cx="12" cy="9" r="5"/><path d="M9 13.5L7.5 21 12 18.5 16.5 21 15 13.5"/>',
  badge: '<circle cx="12" cy="12" r="8"/><path d="M9 12l2 2 4-4"/>',
  star: '<path d="M12 3l2.6 5.6 6.1.8-4.5 4.2 1.1 6.1L12 17l-5.4 2.7 1.1-6.1L3.2 9.4l6.1-.8z"/>',
  phone: '<path d="M5 4h3l2 5-2.5 1.5a11 11 0 005 5L14 13l5 2v3a2 2 0 01-2 2A14 14 0 014 6a2 2 0 011-2z"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  pin: '<path d="M12 21s-6-5.3-6-10a6 6 0 1112 0c0 4.7-6 10-6 10z"/><circle cx="12" cy="11" r="2.5"/>',
  check: '<path d="M20 6L9 17l-5-5"/>',
  leaf: '<path d="M5 19c0-8 6-14 14-14 0 8-6 14-14 14z"/><path d="M5 19c4-4 7-7 10-9"/>',
  arrow: '<path d="M5 12h14"/><path d="M13 6l6 6-6 6"/>',
};
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={paths[name]}
>
</svg>
