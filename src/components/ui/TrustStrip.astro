---
import Icon from './Icon.astro';

const items = [
  { label: 'Fully insured', icon: 'shield' as const },
  { label: 'RSPH Level 2 qualified', icon: 'certificate' as const },
  { label: 'BASIS PROMPT registered', icon: 'badge' as const },
  { label: 'Fast 5-star response', icon: 'star' as const },
];
---

<section class="border-y border-brand-line bg-white" aria-label="Trust signals">
  <div class="site-container grid gap-3 py-5 sm:grid-cols-2 lg:grid-cols-4">
    {items.map((item) => (
      <div class="flex items-center gap-3 rounded-2xl bg-brand-cream px-4 py-3 text-sm font-extrabold text-brand-charcoal">
        <span class="grid h-9 w-9 shrink-0 place-items-center rounded-xl bg-brand-red text-white">
          <Icon name={item.icon} class="h-5 w-5" />
        </span>
        {item.label}
      </div>
    ))}
  </div>
</section>
