---
interface Props {
  quote: string;
  author: string;
  date: string;
  rating: number;
}

const { quote, author, date, rating } = Astro.props;
---

<figure class="rounded-3xl border border-brand-line bg-white p-6 shadow-sm">
  <div class="mb-4 text-sm font-black uppercase tracking-[0.16em] text-brand-red">
    {rating} star review
  </div>
  <blockquote class="text-lg font-bold leading-8 text-brand-charcoal">"{quote}"</blockquote>
  <figcaption class="mt-5 text-sm font-bold text-brand-muted">{author}, {date}</figcaption>
</figure>
