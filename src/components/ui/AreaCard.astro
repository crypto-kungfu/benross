---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Icon from './Icon.astro';

interface Props {
  town: string;
  intro: string;
  href: string;
  image: ImageMetadata;
}

const { town, intro, href, image } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col overflow-hidden rounded-3xl border border-brand-line bg-white shadow-[var(--shadow-card)] transition hover:-translate-y-1 hover:shadow-[var(--shadow-lift)]"
>
  <div class="relative aspect-[16/10] overflow-hidden">
    <Image
      src={image}
      alt={`${town}, North Yorkshire`}
      width={640}
      height={400}
      class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
    />
    <span class="absolute left-4 top-4 inline-flex items-center gap-1 rounded-full bg-brand-red px-3 py-1 text-xs font-black uppercase tracking-[0.12em] text-white">
      <Icon name="pin" class="h-3.5 w-3.5" /> {town}
    </span>
  </div>
  <div class="flex flex-1 flex-col p-6">
    <h3 class="text-xl font-black text-brand-charcoal">Pest Control in {town}</h3>
    <p class="mt-3 flex-1 leading-7 text-brand-muted">{intro}</p>
    <span class="mt-5 inline-flex items-center gap-2 text-sm font-extrabold text-brand-red">
      View {town} page <Icon name="arrow" class="h-4 w-4 transition group-hover:translate-x-1" />
    </span>
  </div>
</a>
