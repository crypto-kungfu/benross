---
import { site } from '../../data/site';
---

<div class="fixed inset-x-0 bottom-0 z-50 border-t border-white/20 bg-brand-red px-4 py-3 text-white shadow-2xl md:hidden">
  <a
    href={site.phoneHref}
    class="flex items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-black text-brand-red"
  >
    Call us now: {site.phoneDisplay}
  </a>
</div>
