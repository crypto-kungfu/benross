---
import { areaImageCredits } from '../../data/image-credits';
import { site } from '../../data/site';
import Logo from '../ui/Logo.astro';
---

<footer class="border-t border-brand-line bg-brand-charcoal pb-24 pt-14 text-white md:pb-14">
  <div class="site-container grid gap-10 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
    <div>
      <div class="mb-4">
        <Logo height={40} variant="footer" />
        <div class="mt-3">
          <p class="font-extrabold">{site.name}</p>
          <p class="text-sm text-white/70">{site.strapline}</p>
        </div>
      </div>
      <p class="max-w-sm text-sm leading-7 text-white/75">
        Local pest control covering {site.coveragePhrase}.
      </p>
    </div>

    <div>
      <h2 class="mb-4 text-sm font-extrabold uppercase tracking-[0.16em] text-white/60">Explore</h2>
      <ul class="space-y-3 text-sm text-white/80">
        {site.nav.map((item) => <li><a class="transition hover:text-white" href={item.href}>{item.label}</a></li>)}
      </ul>
    </div>

    <div>
      <h2 class="mb-4 text-sm font-extrabold uppercase tracking-[0.16em] text-white/60">Areas</h2>
      <ul class="space-y-3 text-sm text-white/80">
        {site.areas.map((area) => <li><a class="transition hover:text-white" href={area.href}>{area.label}</a></li>)}
      </ul>
      <p class="mt-5 text-xs leading-6 text-white/60">
        Service-area business. No public shopfront address.
      </p>
    </div>

    <div>
      <h2 class="mb-4 text-sm font-extrabold uppercase tracking-[0.16em] text-white/60">Contact</h2>
      <ul class="space-y-3 text-sm text-white/80">
        <li><a class="font-bold text-white transition hover:text-white/80" href={site.phoneHref}>{site.phoneDisplay}</a></li>
        <li><a class="transition hover:text-white" href="/contact">Send an enquiry</a></li>
        <li><a class="transition hover:text-white" href={site.facebookUrl}>Facebook</a></li>
      </ul>
    </div>
  </div>

  <div class="site-container mt-12 space-y-3 border-t border-white/10 pt-6 text-xs text-white/55">
    <p>&copy; {new Date().getFullYear()} {site.name}. {site.credentials.join(' - ')}.</p>
    <p class="leading-6">
      Town photos (Wikimedia Commons):{' '}
      {areaImageCredits.map((credit, index) => (
        <>
          {index > 0 && ' · '}
          <a class="underline decoration-white/25 underline-offset-2 transition hover:text-white/80" href={credit.sourceUrl}>
            {credit.title}
          </a>
          {' '}by {credit.author} (
          <a class="underline decoration-white/25 underline-offset-2 transition hover:text-white/80" href={credit.licenseUrl}>
            {credit.license}
          </a>
          )
        </>
      ))}
      .
    </p>
  </div>
</footer>
