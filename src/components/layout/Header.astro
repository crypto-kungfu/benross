---
import { site } from '../../data/site';
import Button from '../ui/Button.astro';
import Logo from '../ui/Logo.astro';

const current = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActive = (href: string) => {
  const normalised = href.replace(/\/$/, '') || '/';
  if (normalised === '/') return current === '/';
  return current === normalised || current.startsWith(`${normalised}/`);
};
---

<header class="sticky top-0 z-40 border-b border-brand-line bg-white/90 backdrop-blur-md">
  <div class="site-container flex items-center justify-between gap-6 py-4">
    <a href="/" class="flex items-center gap-3 font-extrabold text-brand-charcoal" aria-label="BR Pest Control home">
      <Logo height={44} />
      <span class="leading-tight">
        <span class="block text-lg">{site.name}</span>
        <span class="block text-xs font-bold uppercase tracking-[0.18em] text-brand-muted">{site.base}</span>
      </span>
    </a>

    <nav class="hidden items-center gap-7 text-sm font-bold text-brand-ink lg:flex" aria-label="Primary navigation">
      {site.nav.map((item) => (
        <a
          class={`relative transition hover:text-brand-red ${isActive(item.href) ? 'text-brand-red' : ''}`}
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <a class="text-sm font-extrabold text-brand-charcoal transition hover:text-brand-red" href={site.phoneHref}>
        {site.phoneDisplay}
      </a>
      <Button href="/contact">Enquire</Button>
    </div>

    <details class="group relative lg:hidden">
      <summary
        class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-xl border border-brand-line text-brand-charcoal [&::-webkit-details-marker]:hidden"
        aria-label="Open menu"
      >
        <svg class="h-6 w-6 group-open:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg class="hidden h-6 w-6 group-open:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="6" y1="6" x2="18" y2="18" />
          <line x1="6" y1="18" x2="18" y2="6" />
        </svg>
      </summary>

      <div class="absolute right-0 top-full z-50 mt-3 w-64 rounded-2xl border border-brand-line bg-white p-4 shadow-2xl">
        <nav class="grid gap-1 text-sm font-bold text-brand-ink" aria-label="Mobile navigation">
          {site.nav.map((item) => (
            <a
              class={`rounded-xl px-3 py-3 transition hover:bg-brand-cream hover:text-brand-red ${isActive(item.href) ? 'bg-brand-cream text-brand-red' : ''}`}
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <div class="mt-3 grid gap-2 border-t border-brand-line pt-3">
          <a class="rounded-xl px-3 py-3 text-sm font-extrabold text-brand-charcoal transition hover:text-brand-red" href={site.phoneHref}>
            Call {site.phoneDisplay}
          </a>
          <Button href="/contact">Enquire</Button>
        </div>
      </div>
    </details>
  </div>
</header>
