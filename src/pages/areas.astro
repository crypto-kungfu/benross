---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AreaCard from '../components/ui/AreaCard.astro';
import Button from '../components/ui/Button.astro';
import CoverageMap from '../components/ui/CoverageMap.astro';
import Icon from '../components/ui/Icon.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import { areaImages } from '../data/images';
import { site } from '../data/site';

const areas = (await getCollection('areas')).sort((a, b) => a.data.order - b.data.order);

const mapMarkers = site.areas.map((area) => ({
  name: area.name,
  lat: area.lat,
  lng: area.lng,
  href: area.href,
  primary: area.slug === 'ripon',
}));

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Pest control areas covered by BR Pest Control',
  itemListElement: areas.map((area, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: `Pest control in ${area.data.town}`,
    url: `${site.url}/pest-control-${area.data.slug}`,
  })),
};
---

<BaseLayout
  title="Areas We Cover"
  description={`BR Pest Control covers ${site.coveragePhrase}, including nearby towns, villages, farms and rural properties.`}
  path="/areas"
  jsonLd={[itemListSchema]}
>
  <section class="bg-brand-charcoal text-white">
    <div class="site-container py-16">
      <p class="eyebrow text-white/70">Areas</p>
      <h1 class="mt-5 max-w-4xl text-4xl font-black tracking-tight sm:text-5xl">Pest control across Ripon &amp; North Yorkshire</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-white/80">
        Based in Ripon, we cover {site.coveragePhrase}. If your town is not listed, call and ask &mdash; our patch is flexible.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <Button href={site.phoneHref} variant="light" class="gap-2"><Icon name="phone" class="h-5 w-5" /> Call {site.phoneDisplay}</Button>
        <Button href="/contact" variant="inverse">Send an enquiry</Button>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="site-container">
      <SectionHeading
        eyebrow="Coverage map"
        title="Where we work"
        lead="An interactive map of the core coverage area. Tap a marker for that town's pest control page."
      />
      <CoverageMap
        class="mt-8"
        markers={mapMarkers}
        center={site.mapCenter}
        zoom={site.mapCenter.zoom}
        height="520px"
      />
    </div>
  </section>

  <section class="section bg-brand-cream">
    <div class="site-container">
      <SectionHeading eyebrow="Towns" title="Local pest control hubs" lead={`Core pages for ${site.coveragePhrase}.`} />
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {areas.map((area) => (
          <AreaCard
            town={area.data.town}
            label={site.areas.find((entry) => entry.slug === area.data.slug)?.label}
            intro={area.data.intro}
            href={`/pest-control-${area.data.slug}`}
            image={areaImages[area.data.slug]}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-brand-red text-white">
    <div class="site-container flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-center">
      <div>
        <h2 class="text-3xl font-black tracking-tight sm:text-4xl">Not sure if you're in the area?</h2>
        <p class="mt-3 max-w-xl text-lg leading-8 text-white/85">Give us a quick call &mdash; if you're nearby, we can usually help.</p>
      </div>
      <Button href={site.phoneHref} variant="light" class="gap-2"><Icon name="phone" class="h-5 w-5" /> Call {site.phoneDisplay}</Button>
    </div>
  </section>
</BaseLayout>
