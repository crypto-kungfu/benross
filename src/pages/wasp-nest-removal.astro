---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import TestimonialCard from '../components/ui/TestimonialCard.astro';
import { site } from '../data/site';

const areas = (await getCollection('areas')).sort((a, b) => a.data.order - b.data.order);
const testimonials = (await getCollection('testimonials'))
  .filter((testimonial) => !testimonial.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Wasp Nest Removal Ripon & North Yorkshire"
  description="Fast wasp nest removal from BR Pest Control across Ripon, Boroughbridge, Thirsk, Bedale and nearby North Yorkshire villages. Call us for quick help."
  path="/wasp-nest-removal"
>
  <section class="bg-brand-red text-white">
    <div class="site-container grid gap-10 py-16 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div>
        <p class="eyebrow text-white/75">Fast-response pest control</p>
        <h1 class="mt-5 max-w-4xl text-4xl font-black tracking-tight sm:text-6xl">Wasp nest removal across Ripon and North Yorkshire</h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-white/85">
          If wasps are active around a shed, loft, roofline, garage, garden, or outbuilding, call us for safe, practical help.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button href={site.phoneHref} variant="light">Call {site.phoneDisplay}</Button>
          <Button href="/contact" variant="secondary" class="border-white text-white hover:bg-white hover:text-brand-red">
            Send an enquiry
          </Button>
        </div>
      </div>
      {testimonials[0] && (
        <TestimonialCard
          quote={testimonials[0].data.quote}
          author={testimonials[0].data.author}
          date={testimonials[0].data.date}
          rating={testimonials[0].data.rating}
        />
      )}
    </div>
  </section>

  <section class="section bg-brand-cream">
    <div class="site-container grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">What to expect</p>
        <h2 class="mt-3 text-3xl font-black text-brand-charcoal">Clear advice, quick treatment, no fuss</h2>
        <p class="mt-5 lead">
          Wasp nests can become a real problem when they are close to doors, gardens, children's play areas, customers, livestock, or regular working routes.
        </p>
      </div>
      <div class="grid gap-4">
        {[
          'Call us and describe where the wasps are active.',
          'We will advise whether treatment is appropriate and arrange the next step.',
          'After treatment, activity usually reduces as the nest is dealt with.',
        ].map((item, index) => (
          <div class="rounded-3xl border border-brand-line bg-white p-6 shadow-sm">
            <p class="text-sm font-black uppercase tracking-[0.16em] text-brand-red">Step {index + 1}</p>
            <p class="mt-3 text-lg font-bold leading-7 text-brand-charcoal">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="site-container">
      <p class="eyebrow">Wasp nest removal near you</p>
      <h2 class="mt-3 text-3xl font-black text-brand-charcoal">Coverage for wasp nests</h2>
      <p class="mt-4 max-w-2xl lead">
        BR Pest Control handles wasp nest removal across the main service area and surrounding North Yorkshire villages.
      </p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {areas.map((area) => (
          <a class="rounded-2xl border border-brand-line bg-brand-cream p-5 transition hover:border-brand-red" href={`/pest-control-${area.data.slug}`}>
            <h3 class="font-black text-brand-charcoal">Wasp nest removal in {area.data.town}</h3>
            <p class="mt-2 text-sm text-brand-muted">{area.data.intro}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
