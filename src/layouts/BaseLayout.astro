---
import '../styles/global.css';
import Footer from '../components/layout/Footer.astro';
import Header from '../components/layout/Header.astro';
import MobileCallBar from '../components/layout/MobileCallBar.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import Meta from '../components/seo/Meta.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description: string;
  path?: string;
  jsonLd?: Record<string, unknown>[];
}

const { title, description, path = '/', jsonLd = [] } = Astro.props;

const businessSchema = {
  '@context': 'https://schema.org',
  '@id': `${site.url}/#business`,
  '@type': ['LocalBusiness', 'PestControl'],
  name: site.name,
  url: site.url,
  telephone: site.phoneE164,
  email: `${site.emailUser}@${site.emailDomain}`,
  description,
  areaServed: [
    ...site.areas.map((area) => ({
      '@type': 'City',
      name: area.name,
    })),
    {
      '@type': 'AdministrativeArea',
      name: 'North Yorkshire',
    },
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Ripon',
    addressRegion: 'North Yorkshire',
    addressCountry: 'GB',
  },
  sameAs: [site.facebookUrl],
};

const schemas = [businessSchema, ...jsonLd];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#c8102e" />
    <Meta title={title} description={description} path={path} />
    <JsonLd data={schemas} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <MobileCallBar />
  </body>
</html>
